diff --git a/crates/rolldown_binding/src/lib.rs b/crates/rolldown_binding/src/lib.rs
index b140a42..dcd859d 100644
--- a/crates/rolldown_binding/src/lib.rs
+++ b/crates/rolldown_binding/src/lib.rs
@@ -68,6 +68,23 @@ pub fn shutdown_async_runtime() {
   }
 }
 
+#[napi]
+/// Cooperatively drive the tokio runtime from the JS thread.
+///
+/// Single-threaded wasm builds have no thread to run async tasks; the JS
+/// glue calls this in a loop (yielding to the event loop between calls)
+/// until the pending operation's promise settles.
+pub fn pump_async_runtime(budget: u32) {
+  #[cfg(all(target_family = "wasm", not(tokio_unstable)))]
+  {
+    napi::bindgen_prelude::pump_tokio_runtime(budget);
+  }
+  #[cfg(not(all(target_family = "wasm", not(tokio_unstable))))]
+  {
+    let _ = budget;
+  }
+}
+
 #[napi]
 /// Start the async runtime manually.
 ///
