node_modules/
app/dist/
harness/workerd-dist/
harness/baseline-dist/
harness/node_modules/
*.log
.DS_Store

# miniflare local cache
.wrangler/
**/.wrangler/
experiments/npm-in-workerd/do-shell/worker/rolldown.wasm

# published fork tarballs live on npm now — never commit the big tgz blobs
packages/**/*.tgz
*.tgz

# packages/{rolldown,vite} are regenerable `npm pack` output (the packages live
# on npm); only packages/PUBLISH.md is tracked. Recover with `npm pack @netanelgilad/<pkg>`.
packages/rolldown/
packages/vite/

# prep-install-url uses a node_modules symlink into the npm-in-workerd experiment
prep-install-url/node_modules

# base-image build artifacts (regenerable from build.mjs)
experiments/npm-in-workerd/base-image/.staging/
experiments/npm-in-workerd/base-image/*.tar.gz
